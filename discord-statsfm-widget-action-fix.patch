+# Copy this file to .env for local development:
+#   cp .env.example .env
+# Then fill in the required values below.
+
+# Required
+DISCORD_APP_ID=
+DISCORD_USER_ID=
+DISCORD_BOT_TOKEN=
+LASTFM_API_KEY=
+LASTFM_USERNAME=
+
+# Optional but recommended for corrected album art, same as Discord-Lyrically-Widget.
+# Create a Discord channel webhook and paste the webhook URL here.
+DISCORD_IMAGE_WEBHOOK_URL=
+
+# Alternative to webhook upload. The bot must have permission to send messages/files.
+DISCORD_TARGET_CHANNEL_ID=
+
+# Optional — defaults to https://www.last.fm/user/{LASTFM_USERNAME}
+LASTFM_PROFILE_URL=
+
+# Optional. Idle gif should normally be configured as the Image/Hero Application Asset
+# fallback in Discord's widget editor. Playing sends album art as hero_image;
+# idle omits hero_image so Discord shows that fallback asset.
+IDLE_IMAGE_URL=
+
+# Backup poll for Discord Spotify presence.
+POLL_SECONDS=5
+
+# How often to refresh Last.fm top/stat pages.
+TOPS_POLL_SECONDS=60
+
+# Kept for compatibility.
+CURRENT_TRACK_WINDOW_SECONDS=300
+
+# Rotate bottom 6 stat cards.
+ROTATING_STATS=true
+ROTATION_INTERVAL_SECONDS=30
+
+# Slash commands. Guild-scoped is instant; global commands can take time.
+COMMANDS_GLOBAL=false
+COMMANDS_GUILD_ID=
+
+# D.W.I.F-style image correction for album art.
+# Requires DISCORD_IMAGE_WEBHOOK_URL or DISCORD_TARGET_CHANNEL_ID so the processed PNG can be uploaded to Discord CDN.
+WIDGET_IMAGE_FIX=true
+IMAGE_CACHE_DIR=.cache/images
+
+# GitHub Actions daemon mode. 0 = run forever (local/VPS).
+# Workflow sets this to 21000 seconds (~5h50m) automatically.
+MAX_RUNTIME_SECONDS=0
+

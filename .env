# Discord application / user IDs (public identifiers, not secrets)
DISCORD_APP_ID=your_discord_app_id
DISCORD_USER_ID=your_discord_user_id

# Bot token from the Discord Developer Portal → Bot → Reset Token / Copy.
# Fill this in before running. Do not push your real token to GitHub.
DISCORD_BOT_TOKEN=

# stats.fm profile
STATSM_USERNAME=your_statsfm_username
# Optional — defaults to https://stats.fm/{STATSM_USERNAME}
STATSM_PROFILE_URL=

# Unused for animation. Idle gif must be the Image/Hero Application Asset
# fallback in the widget editor (User Data URLs never animate).
# Playing → album art URL is sent as hero_image; idle → hero_image is omitted
# so Discord shows that Application Asset fallback gif.
IDLE_IMAGE_URL=

# Backup poll for Discord Spotify presence (track changes also update instantly).
POLL_SECONDS=5
# How often to refresh stats.fm top artist/album/song.
TOPS_POLL_SECONDS=60
# Kept for compatibility (now-playing uses Discord presence, not this window).
CURRENT_TRACK_WINDOW_SECONDS=300

# Rotate bottom 6 stat cards (same Discord field names, different values per page).
ROTATING_STATS=true
ROTATION_INTERVAL_SECONDS=30

# Slash commands (Active Developer Badge).
# Guild-scoped = instant updates (default). Set COMMANDS_GLOBAL=true for global.
COMMANDS_GLOBAL=false
# Your dev server ID. Leave empty to use the first guild the bot is in.
COMMANDS_GUILD_ID=

# Optional overrides if the default stats.fm endpoints change.
# Leave blank to use built-in defaults derived from STATSM_USERNAME.
STATSM_RECENT_URL=
STATSM_TOP_ARTISTS_4W_URL=
STATSM_TOP_ALBUMS_4W_URL=
STATSM_TOP_TRACKS_4W_URL=
STATSM_TOP_ARTISTS_6M_URL=
STATSM_TOP_ALBUMS_6M_URL=
STATSM_TOP_TRACKS_6M_URL=
